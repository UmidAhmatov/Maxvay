DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,server-public-ip
DJANGO_CSRF_TRUSTED_ORIGINS=http://your-domain.com,http://www.your-domain.com
DJANGO_DB_PATH=/app/data/maxway_django.sqlite3
DJANGO_CREATE_DEMO_ADMIN=1
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-this-admin-password
DJANGO_SUPERUSER_EMAIL=admin@maxway.local
